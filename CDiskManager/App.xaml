<Application
    x:Class="CDiskManager.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:CDiskManager.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolNegationConverter x:Key="BoolNegation"/>
            <helpers:UsageColorConverter x:Key="UsageColor"/>
            <helpers:FileGlyphConverter x:Key="FileGlyph"/>
            <helpers:EmptyToVisibilityConverter x:Key="EmptyToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
