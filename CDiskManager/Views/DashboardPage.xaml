<Page
    x:Class="CDiskManager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models"
    Loaded="Page_Loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="36,24">
        <StackPanel Spacing="16">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="C 盘空间中心" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Grid.Row="1"
                           Text="先看系统盘是否危险，再选择扫描、清理或查找大文件。"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Bind ViewModel.CDriveLabel, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.HealthText, Mode=OneWay}"
                                       Foreground="{x:Bind ViewModel.CDrivePercent, Mode=OneWay, Converter={StaticResource UsageColor}}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.RecommendationText, Mode=OneWay}"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" MaxWidth="150">
                            <TextBlock Text="{x:Bind ViewModel.PercentLabel, Mode=OneWay}"
                                       FontSize="36" FontWeight="SemiBold"
                                       Foreground="{x:Bind ViewModel.CDrivePercent, Mode=OneWay, Converter={StaticResource UsageColor}}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right"/>
                            <TextBlock Text="已使用" HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <ProgressBar Value="{x:Bind ViewModel.CDrivePercent, Mode=OneWay}"
                                 Maximum="100" Height="12" CornerRadius="6"
                                 Foreground="{x:Bind ViewModel.CDrivePercent, Mode=OneWay, Converter={StaticResource UsageColor}}"/>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="可用空间" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CDriveFree, Mode=OneWay}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.FreePercentLabel, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="已使用" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CDriveUsed, Mode=OneWay}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="总容量" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CDriveTotal, Mode=OneWay}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="文件系统" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CDriveFormat, Mode=OneWay}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="GoToScan" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9F5;" FontSize="16"/>
                                <TextBlock Text="{x:Bind ViewModel.PrimaryActionText, Mode=OneWay}"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="GoToCleanup">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                <TextBlock Text="清理可释放项"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Click="GoToSettings">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                                <TextBlock Text="迁移客户端缓存"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Click="Refresh_Click" ToolTipService.ToolTip="刷新磁盘信息">
                            <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE9F5;" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="空间扫描" FontWeight="SemiBold"/>
                        <TextBlock Text="逐层查看哪些目录占用最多"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Content="查看目录占用" Click="GoToScan"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE74D;" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="垃圾清理" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.CleanupHint, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Content="扫描可清理项" Click="GoToCleanup"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE8B7;" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="大文件" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.LargeFileHint, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Content="查找大文件" Click="GoToLargeFiles"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="重复文件" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.DuplicateHint, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Content="查找重复文件" Click="GoToDuplicateFiles"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="客户端缓存迁移" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.CacheRelocationHint, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="设置迁移" Click="GoToSettings" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- All Partitions -->
            <TextBlock Text="所有分区" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>

            <ItemsRepeater x:Name="PartitionList" ItemsSource="{x:Bind ViewModel.Partitions, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="280" MinItemHeight="110"
                                       MinColumnSpacing="12" MinRowSpacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:PartitionInfo">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{x:Bind DriveLetter}"/>
                                        <Run Text="  "/>
                                        <Run Text="{x:Bind Label}"/>
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind DriveFormat}" HorizontalAlignment="Right"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <ProgressBar Value="{x:Bind UsagePercent}" Maximum="100" Height="8"
                                             Foreground="{x:Bind UsagePercent, Converter={StaticResource UsageColor}}"/>
                                <Grid>
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind UsedFormatted}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{x:Bind TotalFormatted}"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Right"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind FreeFormatted}"/>
                                        <Run Text=" 可用"/>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
