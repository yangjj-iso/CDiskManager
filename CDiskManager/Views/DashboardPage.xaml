<Page
    x:Class="CDiskManager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models"
    Loaded="Page_Loaded">

    <ScrollViewer Padding="36,24">
        <StackPanel Spacing="24">
            <TextBlock Text="C 盘概览" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- C Drive summary card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="28">
                <Grid ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Usage ring -->
                    <Grid Width="160" Height="160">
                        <ProgressRing IsIndeterminate="False"
                                      Width="150" Height="150"
                                      Foreground="{x:Bind ViewModel.CDrivePercent, Mode=OneWay, Converter={StaticResource UsageColor}}"
                                      Value="{x:Bind ViewModel.CDrivePercent, Mode=OneWay}"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.PercentLabel, Mode=OneWay}"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource TitleTextBlockStyle}"/>
                            <TextBlock Text="已使用" HorizontalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="{x:Bind ViewModel.HealthText, Mode=OneWay}"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{x:Bind ViewModel.CDrivePercent, Mode=OneWay, Converter={StaticResource UsageColor}}"/>
                        <Grid ColumnSpacing="24" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="总容量" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CDriveTotal, Mode=OneWay}"
                                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="已使用" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CDriveUsed, Mode=OneWay}"
                                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="可用" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CDriveFree, Mode=OneWay}"
                                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- All Partitions -->
            <TextBlock Text="所有分区" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>

            <ItemsRepeater x:Name="PartitionList" ItemsSource="{x:Bind ViewModel.Partitions, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="280" MinItemHeight="110"
                                       MinColumnSpacing="12" MinRowSpacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:PartitionInfo">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{x:Bind DriveLetter}"/>
                                        <Run Text="  "/>
                                        <Run Text="{x:Bind Label}"/>
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind DriveFormat}" HorizontalAlignment="Right"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <ProgressBar Value="{x:Bind UsagePercent}" Maximum="100" Height="8"
                                             Foreground="{x:Bind UsagePercent, Converter={StaticResource UsageColor}}"/>
                                <Grid>
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind UsedFormatted}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{x:Bind TotalFormatted}"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Right"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind FreeFormatted}"/>
                                        <Run Text=" 可用"/>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Quick Actions -->
            <TextBlock Text="快捷操作" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Click="GoToScan" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9F5;" FontSize="16"/>
                        <TextBlock Text="扫描空间"/>
                    </StackPanel>
                </Button>
                <Button Click="GoToCleanup">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                        <TextBlock Text="清理垃圾"/>
                    </StackPanel>
                </Button>
                <Button Click="GoToLargeFiles">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                        <TextBlock Text="查找大文件"/>
                    </StackPanel>
                </Button>
                <Button Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
