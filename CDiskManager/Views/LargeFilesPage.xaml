<Page
    x:Class="CDiskManager.Views.LargeFilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models">

    <Grid Padding="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="大文件检测" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,12">
            <Button Content="开始扫描" Command="{x:Bind ViewModel.ScanCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
            <Button Content="取消" Command="{x:Bind ViewModel.CancelCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay}"/>
            <ComboBox MinWidth="90" VerticalAlignment="Center"
                      ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                      SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                      ToolTipService.ToolTip="选择要扫描的分区"/>
            <TextBlock Text="最小大小 (MB):" VerticalAlignment="Center" Margin="8,0,8,0"/>
            <NumberBox Value="{x:Bind ViewModel.MinSizeMB, Mode=TwoWay}"
                       Minimum="1" Maximum="1000000" SpinButtonPlacementMode="Compact"
                       SmallChange="50" LargeChange="500" Width="130"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                          Width="24" Height="24" Margin="12,0,0,0"/>
            <TextBlock Text="{x:Bind ViewModel.CurrentPath, Mode=OneWay}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       MaxWidth="280"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Batch action bar -->
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" HorizontalAlignment="Left"
                    Background="Transparent"
                    Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay}">
            <AppBarButton Icon="Delete" Label="删除所选" Click="DeleteSelected_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="OpenFile" Label="打开所在位置" Click="OpenSelected_Click"/>
        </CommandBar>

        <!-- File list -->
        <ListView Grid.Row="3" x:Name="FilesList"
                  ItemsSource="{x:Bind ViewModel.LargeFiles, Mode=OneWay}"
                  SelectionMode="Extended">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                    <Grid Padding="4,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  Glyph="{x:Bind Extension, Converter={StaticResource FileGlyph}}"
                                  FontSize="20" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind DirectoryPath}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Right" MinWidth="110">
                            <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{x:Bind LastModifiedFormatted}"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                            <Button ToolTipService.ToolTip="在资源管理器中打开"
                                    Click="OpenOne_Click" Tag="{x:Bind}">
                                <FontIcon Glyph="&#xE8DA;" FontSize="14"/>
                            </Button>
                            <Button ToolTipService.ToolTip="移入回收站"
                                    Click="DeleteOne_Click" Tag="{x:Bind}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
