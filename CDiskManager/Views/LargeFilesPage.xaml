<Page
    x:Class="CDiskManager.Views.LargeFilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="大文件检测" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,16,0,12" Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="开始扫描" Command="{x:Bind ViewModel.ScanCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <Button Grid.Column="1" Content="取消" Command="{x:Bind ViewModel.CancelCommand}"
                        IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay}"/>
                <ComboBox Grid.Column="2" MinWidth="92" VerticalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                          SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                          ToolTipService.ToolTip="选择要扫描的分区"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="最小大小" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <NumberBox Value="{x:Bind ViewModel.MinSizeMB, Mode=TwoWay}"
                               Minimum="1" Maximum="1000000" SpinButtonPlacementMode="Compact"
                               SmallChange="50" LargeChange="500" Width="120"/>
                    <TextBlock Text="MB" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                                  Width="22" Height="22"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentPath, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="240"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="14" Margin="0,0,0,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="结果摘要" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Click="OpenSelected_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8DA;" FontSize="14"/>
                        <TextBlock Text="打开所选位置"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Click="DeleteSelected_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="删除所选"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- File list -->
        <Grid Grid.Row="3">
            <ListView x:Name="FilesList"
                      ItemsSource="{x:Bind ViewModel.LargeFiles, Mode=OneWay}"
                      SelectionMode="Extended">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                    <Grid Padding="4,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  Glyph="{x:Bind Extension, Converter={StaticResource FileGlyph}}"
                                  FontSize="20" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind DirectoryPath}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Right" MinWidth="110">
                            <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{x:Bind LastModifiedFormatted}"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                            <Button ToolTipService.ToolTip="在资源管理器中打开"
                                    Click="OpenOne_Click" Tag="{x:Bind}">
                                <FontIcon Glyph="&#xE8DA;" FontSize="14"/>
                            </Button>
                            <Button ToolTipService.ToolTip="移入回收站"
                                    Click="DeleteOne_Click" Tag="{x:Bind}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            </ListView>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
                <FontIcon Glyph="&#xE8B7;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="尚未扫描大文件" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="选择分区和阈值后点击「开始扫描」，这里会显示可处理的大文件列表。"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
