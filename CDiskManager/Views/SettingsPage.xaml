<Page
    x:Class="CDiskManager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="36,24">
        <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Appearance -->
            <TextBlock Text="外观" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE771;" FontSize="20" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="主题" FontWeight="SemiBold"/>
                        <TextBlock Text="选择应用的明暗主题"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="2" MinWidth="140"
                              ItemsSource="{x:Bind ViewModel.ThemeOptions}"
                              SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <!-- Scan defaults -->
            <TextBlock Text="扫描默认值" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xEDA2;" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="默认扫描分区" FontWeight="SemiBold"/>
                            <TextBlock Text="新建扫描时默认选择的磁盘"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="2" MinWidth="140"
                                  ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                                  SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"/>
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="大文件阈值 (MB)" FontWeight="SemiBold"/>
                            <TextBlock Text="超过该大小的文件会被标记为大文件"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <NumberBox Grid.Column="2" MinWidth="140"
                                   Value="{x:Bind ViewModel.LargeFileMinMB, Mode=TwoWay}"
                                   Minimum="1" Maximum="1000000" SpinButtonPlacementMode="Compact"/>
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8C8;" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="重复文件最小大小 (MB)" FontWeight="SemiBold"/>
                            <TextBlock Text="小于该大小的文件不参与重复检测"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <NumberBox Grid.Column="2" MinWidth="140"
                                   Value="{x:Bind ViewModel.DuplicateMinMB, Mode=TwoWay}"
                                   Minimum="0.1" Maximum="100000" SpinButtonPlacementMode="Compact"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Safety -->
            <TextBlock Text="安全" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE74D;" FontSize="20" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="删除到回收站" FontWeight="SemiBold"/>
                        <TextBlock Text="关闭后将永久删除文件，无法还原"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="2" IsOn="{x:Bind ViewModel.UseRecycleBin, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <!-- Cache relocation -->
            <TextBlock Text="缓存迁移" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="设置 QQ/微信缓存目录到其他盘" FontWeight="SemiBold"/>
                            <TextBlock Text="移动 QQ、微信、企业微信等客户端缓存目录到目标盘，并在原路径创建目录联接，让客户端继续使用原路径写入"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                            <ComboBox MinWidth="110"
                                      HorizontalAlignment="Right"
                                      ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                                      SelectedItem="{x:Bind ViewModel.CacheTargetDrive, Mode=TwoWay}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="刷新" Command="{x:Bind ViewModel.RefreshRelocatableCachesCommand}"/>
                                <Button Content="推荐" Command="{x:Bind ViewModel.SelectRecommendedRelocatableCachesCommand}"/>
                                <Button Content="全选" Command="{x:Bind ViewModel.SelectAllRelocatableCachesCommand}"/>
                                <Button Content="清空" Command="{x:Bind ViewModel.ClearRelocatableCacheSelectionCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="迁移缓存" Click="RelocateCaches_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        IsEnabled="{x:Bind ViewModel.CanRelocateCaches, Mode=OneWay}"/>
                                <Button Content="取消迁移" Command="{x:Bind ViewModel.CancelCacheRelocationCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsRelocatingCaches, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <InfoBar IsOpen="True" IsClosable="False" Severity="Warning"
                             Title="迁移方式"
                             Message="先关闭 QQ、微信、企业微信等相关客户端，选择 C 盘以外的目标盘，勾选缓存后点击迁移。聊天文件、数据库和登录配置会标为高风险且不会默认勾选。"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind ViewModel.CacheRelocationStatus, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <ProgressRing Grid.Column="1"
                                      IsActive="{x:Bind ViewModel.IsRelocatingCaches, Mode=OneWay}"
                                      Width="20" Height="20"/>
                    </Grid>

                    <ListView ItemsSource="{x:Bind ViewModel.RelocatableCaches, Mode=OneWay}"
                              MaxHeight="180"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Center"
                                              IsEnabled="{Binding CanSelect}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Padding="6,1" CornerRadius="4"
                                                    Background="{ThemeResource AccentFillColorTertiaryBrush}">
                                                <TextBlock Text="{Binding ClientLabel}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SourcePath}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding TargetPath}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding WarningText}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding WarningText, Converter={StaticResource EmptyToVisibility}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Border Padding="6,1" CornerRadius="4"
                                                HorizontalAlignment="Right"
                                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                                Visibility="{Binding RecommendationLabel, Converter={StaticResource EmptyToVisibility}}">
                                            <TextBlock Text="{Binding RecommendationLabel}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding SizeFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   HorizontalAlignment="Right"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                <Button Content="恢复默认设置" Command="{x:Bind ViewModel.ResetDefaultsCommand}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- About -->
            <TextBlock Text="关于" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="CDiskManager" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.Version}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="一款用于分析与清理 Windows C 盘空间的工具。"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
