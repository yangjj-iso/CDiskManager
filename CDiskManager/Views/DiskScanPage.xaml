<Page
    x:Class="CDiskManager.Views.DiskScanPage"
    x:Name="ScanRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="磁盘空间扫描" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,16,0,12" Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="开始扫描" Command="{x:Bind ViewModel.StartScanCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <Button Grid.Column="1" Content="取消" Command="{x:Bind ViewModel.CancelScanCommand}"
                        IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay}"/>
                <ComboBox Grid.Column="2" MinWidth="92" VerticalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                          SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                          ToolTipService.ToolTip="选择要扫描的分区"/>
                <Button Grid.Column="3" Command="{x:Bind ViewModel.NavigateUpCommand}"
                        ToolTipService.ToolTip="返回上级目录">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                        <TextBlock Text="上级"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                                  Width="22" Height="22"/>
                    <TextBlock VerticalAlignment="Center"
                               Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="{x:Bind ViewModel.FileCount, Mode=OneWay}"/>
                        <Run Text=" 个文件 · "/>
                        <Run Text="{x:Bind ViewModel.BytesScanned, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Breadcrumb + current path while scanning -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <BreadcrumbBar ItemsSource="{x:Bind ViewModel.Breadcrumbs, Mode=OneWay}"
                           ItemClicked="Breadcrumb_ItemClicked"
                           Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource EmptyToVisibility}, ConverterParameter=invert}">
                <BreadcrumbBar.ItemTemplate>
                    <DataTemplate x:DataType="models:FolderNode">
                        <TextBlock Text="{x:Bind Name}"/>
                    </DataTemplate>
                </BreadcrumbBar.ItemTemplate>
            </BreadcrumbBar>
            <TextBlock Text="{x:Bind ViewModel.CurrentPath, Mode=OneWay}"
                       TextTrimming="CharacterEllipsis"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
        </Grid>

        <Border Grid.Row="3" Padding="16" Margin="0,0,0,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Visibility="{x:Bind ViewModel.HasScanResult, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
            <StackPanel Spacing="10">
                <Grid>
                    <TextBlock Text="{x:Bind ViewModel.SummaryTitle, Mode=OneWay}" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentSizeText, Mode=OneWay}"
                               HorizontalAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.TopConsumers, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:FolderNode">
                            <Grid Padding="0,4" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Grid.Column="1" Value="{x:Bind DisplayPercent}" Maximum="100"
                                             Height="6" CornerRadius="3" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind PercentLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Border>

        <!-- Folder / file list -->
        <Grid Grid.Row="4" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.HasScanResult, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
                <Grid Padding="12,0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="76"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="名称" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="大小 / 占比" HorizontalAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="104"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Bind ViewModel.ChildFilterSummary, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBox Grid.Column="1"
                             PlaceholderText="筛选当前目录"
                             Text="{x:Bind ViewModel.ChildFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{x:Bind ViewModel.ChildTypeFilterOptions}"
                              SelectedIndex="{x:Bind ViewModel.ChildTypeFilterIndex, Mode=TwoWay}"/>
                </Grid>
            </StackPanel>
            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.CurrentChildren, Mode=OneWay}"
                      SelectionMode="Single" ItemClick="FolderItem_Click" IsItemClickEnabled="True">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FolderNode">
                        <Grid Padding="4,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="76"/>
                            </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" FontSize="18"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Value="{x:Bind DisplayPercent}" Maximum="100"
                                         Height="5" CornerRadius="3"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Text="{x:Bind SizeFormatted}"/>
                            <TextBlock HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind PercentLabel}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button ToolTipService.ToolTip="在资源管理器中打开"
                                    Command="{Binding DataContext.OpenInExplorerCommand, ElementName=ScanRoot}"
                                    CommandParameter="{Binding}">
                                <FontIcon Glyph="&#xE8DA;" FontSize="13"/>
                            </Button>
                            <FontIcon Glyph="&#xE76C;" FontSize="12"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Visibility="{x:Bind IsDirectory, Converter={StaticResource EmptyToVisibility}}"/>
                        </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
                <FontIcon Glyph="&#xE9F5;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="尚未扫描磁盘" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="选择分区后点击「开始扫描」，这里会显示主要占用和目录列表。"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
