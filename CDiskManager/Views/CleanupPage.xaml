<Page
    x:Class="CDiskManager.Views.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="垃圾清理" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Admin notice -->
        <InfoBar Grid.Row="1" x:Name="AdminBar" Margin="0,12,0,0"
                 IsClosable="False" Severity="Warning"
                 Title="部分系统目录需要管理员权限"
                 Message="以管理员身份运行可清理 Windows 临时文件、Prefetch 等受保护目录。">
            <InfoBar.ActionButton>
                <Button Content="以管理员身份重启" Click="RestartAdmin_Click"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <Border Grid.Row="2" Margin="0,16,0,12" Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="扫描可清理项" Command="{x:Bind ViewModel.ScanCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <Button Grid.Column="1" Content="清理勾选项" Click="Clean_Click"
                        IsEnabled="{x:Bind ViewModel.CanCleanSelected, Mode=OneWay}"/>
                <Button Grid.Column="2" Content="取消" Command="{x:Bind ViewModel.CancelCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay}"/>
                <Button Grid.Column="3" Content="低风险" Command="{x:Bind ViewModel.SelectRecommendedCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <Button Grid.Column="4" Content="全选" Command="{x:Bind ViewModel.SelectAllCleanableCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <Button Grid.Column="5" Content="清空" Command="{x:Bind ViewModel.ClearSelectionCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                                  Width="22" Height="22"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalCleanable, Mode=OneWay}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="可清理" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Padding="12,0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="132"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="2" Text="清理项" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="大小 / 结果" HorizontalAlignment="Right"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>
            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CleanupCategory">
                        <Grid Padding="4,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="132"/>
                            </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" MinWidth="0"
                                  IsEnabled="{x:Bind CanSelect, Mode=OneWay}"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>

                        <FontIcon Grid.Column="1" Glyph="{x:Bind Glyph}" FontSize="20"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <Border Padding="6,1" CornerRadius="4"
                                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                        Visibility="{x:Bind RiskLabel, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
                                    <TextBlock Text="{x:Bind RiskLabel}"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{x:Bind Description}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind WarningText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{x:Bind WarningText, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
                            <TextBlock Text="{x:Bind ScanSummary, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ScanSummary, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
                            <TextBlock Text="{x:Bind StatusDetail, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind StatusDetail, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Center" MinWidth="112">
                            <ProgressRing IsActive="{x:Bind IsCalculating, Mode=OneWay}"
                                          Width="16" Height="16" HorizontalAlignment="Right"/>
                            <TextBlock Text="{x:Bind SizeFormatted, Mode=OneWay}"
                                       FontWeight="SemiBold" HorizontalAlignment="Right"
                                       Visibility="{x:Bind IsCalculating, Mode=OneWay, Converter={StaticResource EmptyToVisibility}, ConverterParameter=invert}"/>
                            <TextBlock Text="{x:Bind FailedSummary, Mode=OneWay}"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Visibility="{x:Bind FailedSummary, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
                            <TextBlock Text="{x:Bind DeletedSummary, Mode=OneWay}"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind DeletedSummary, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
                        </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
                <FontIcon Glyph="&#xE74D;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="尚未扫描可清理项" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="点击「扫描可清理项」，这里会列出临时文件、缓存、回收站等可释放空间。"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Total / progress -->
        <Border Grid.Row="4" Padding="16" Margin="0,12,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="剩余可清理: "/>
                        <Run Text="{x:Bind ViewModel.TotalCleanable, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Text="{x:Bind ViewModel.SelectionSummary, Mode=OneWay}"
                               Margin="0,22,32,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ProgressRing IsActive="{x:Bind ViewModel.IsCleaning, Mode=OneWay}"
                                  Width="20" Height="20" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar Value="{x:Bind ViewModel.CleanProgress, Mode=OneWay}" Maximum="100"
                             Visibility="{x:Bind ViewModel.IsCleaning, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
