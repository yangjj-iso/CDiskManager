<Page
    x:Class="CDiskManager.Views.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models">

    <Grid Padding="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="垃圾清理" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Admin notice -->
        <InfoBar Grid.Row="1" x:Name="AdminBar" Margin="0,12,0,0"
                 IsClosable="False" Severity="Warning"
                 Title="部分系统目录需要管理员权限"
                 Message="以管理员身份运行可清理 Windows 临时文件、Prefetch 等受保护目录。">
            <InfoBar.ActionButton>
                <Button Content="以管理员身份重启" Click="RestartAdmin_Click"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,12">
            <Button Content="扫描" Command="{x:Bind ViewModel.ScanCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
            <Button Content="一键清理" Click="Clean_Click"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                          Width="24" Height="24"/>
        </StackPanel>

        <!-- Category list -->
        <ListView Grid.Row="3" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:CleanupCategory">
                    <Grid Padding="4,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" MinWidth="0"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>

                        <FontIcon Grid.Column="1" Glyph="{x:Bind Glyph}" FontSize="20"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Description}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <Grid Grid.Column="3" VerticalAlignment="Center" MinWidth="80">
                            <ProgressRing IsActive="{x:Bind IsCalculating, Mode=OneWay}"
                                          Width="16" Height="16" HorizontalAlignment="Right"/>
                            <TextBlock Text="{x:Bind SizeFormatted, Mode=OneWay}"
                                       FontWeight="SemiBold" HorizontalAlignment="Right"
                                       Visibility="{x:Bind IsCalculating, Mode=OneWay, Converter={StaticResource EmptyToVisibility}, ConverterParameter=invert}"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Total / progress -->
        <Border Grid.Row="4" Padding="16" Margin="0,12,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="可清理总计: "/>
                        <Run Text="{x:Bind ViewModel.TotalCleanable, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <ProgressRing IsActive="{x:Bind ViewModel.IsCleaning, Mode=OneWay}"
                                  Width="20" Height="20" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar Value="{x:Bind ViewModel.CleanProgress, Mode=OneWay}" Maximum="100"
                             Visibility="{x:Bind ViewModel.IsCleaning, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
