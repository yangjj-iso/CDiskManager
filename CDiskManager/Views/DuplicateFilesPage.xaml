<Page
    x:Class="CDiskManager.Views.DuplicateFilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CDiskManager.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="重复文件检测" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,16,0,12" Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="14" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="开始扫描" Command="{x:Bind ViewModel.ScanCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolNegation}}"/>
                <Button Grid.Column="1" Content="取消" Command="{x:Bind ViewModel.CancelCommand}"
                        IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay}"/>
                <ComboBox Grid.Column="2" MinWidth="92" VerticalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                          SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                          ToolTipService.ToolTip="选择要扫描的分区"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="最小大小" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <NumberBox Value="{x:Bind ViewModel.MinSizeMB, Mode=TwoWay}"
                               Minimum="0.1" Maximum="100000" SpinButtonPlacementMode="Compact"
                               SmallChange="1" LargeChange="10" Width="112"/>
                    <TextBlock Text="MB" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                                  Width="22" Height="22"/>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="已扫描 "/>
                        <Run Text="{x:Bind ViewModel.ScannedCount, Mode=OneWay}"/>
                        <Run Text=" 个文件"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="14" Margin="0,0,0,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="结果摘要" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectionSummary, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectRecommendedCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8FB;" FontSize="14"/>
                        <TextBlock Text="推荐选择"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Command="{x:Bind ViewModel.ClearSelectionCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                        <TextBlock Text="清空选择"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Click="DeleteSelected_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="删除勾选文件"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" Text="重复文件分组" FontWeight="SemiBold" Margin="0,0,0,8"
                   Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}"/>

        <Grid Grid.Row="4">
            <ListView ItemsSource="{x:Bind ViewModel.DuplicateGroups, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:DuplicateGroup">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,4">
                            <StackPanel Spacing="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind Header}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Detail}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                               Foreground="{ThemeResource SystemFillColorCautionBrush}">
                                        <Run Text="可释放 "/>
                                        <Run Text="{x:Bind TotalWaste}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </Grid>
                                <ItemsRepeater ItemsSource="{x:Bind Files}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:FileItem">
                                            <Grid Padding="0,7" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="112"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" MinWidth="0"
                                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>
                                                <TextBlock Grid.Column="1" Text="{x:Bind DuplicateActionText, Mode=OneWay}"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{x:Bind DirectoryPath}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{x:Bind LastModifiedFormatted}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <Button Grid.Column="4" VerticalAlignment="Center"
                                                        ToolTipService.ToolTip="打开所在位置"
                                                        Click="OpenOne_Click" Tag="{x:Bind}">
                                                    <FontIcon Glyph="&#xE8DA;" FontSize="14"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource EmptyToVisibility}}">
                <FontIcon Glyph="&#xE8C8;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="尚未扫描重复文件" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="选择分区和最小大小后点击「开始扫描」，这里会按内容相同的文件分组显示。"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
